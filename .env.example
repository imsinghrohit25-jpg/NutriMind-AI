# ============================================================================
# NutriMind AI — environment template (Phase 0)
# Copy to .env (backend) — NEVER commit real values. Secret scan runs in CI.
# Each var is annotated with the phase that first requires it.
# "Code complete, credential pending" is the only acceptable incomplete state.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (Phase 1) — local dev: `supabase start` prints these
# ----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # backend/workers only — never ships in mobile
SUPABASE_JWKS_URL=                    # https://<ref>.supabase.co/auth/v1/.well-known/jwks.json — asymmetric JWT verification (Phase 2)
DATABASE_URL=                         # Postgres conn string — migrations, pg-boss (Phase 1–2)

# ----------------------------------------------------------------------------
# API service (Phase 2)
# ----------------------------------------------------------------------------
API_PORT=3000
API_ENV=development                   # development | staging | production
RATE_LIMIT_USER_PER_MIN=60            # per-user sliding window
CORS_ALLOWED_ORIGINS=

# ----------------------------------------------------------------------------
# AI Gateway — model providers (Phase 2; all four adapters must be provable)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=                       # Google AI Studio key
OPENAI_COMPAT_BASE_URL=               # e.g. http://localhost:11434/v1 (Ollama/vLLM)
OPENAI_COMPAT_API_KEY=
LLM_ROUTING_CONFIG=config/routing.json  # task-tier → model policy (checked into repo)
LLM_MONTHLY_BUDGET_USD=               # cost-log alerting threshold (Grafana)

# ----------------------------------------------------------------------------
# Real food data sources (Phase 3) — see docs/DATA_SOURCES.md
# ----------------------------------------------------------------------------
USDA_FDC_API_KEY=                     # free: https://fdc.nal.usda.gov/api-key-signup
OFF_BASE_URL=https://world.openfoodfacts.org
OFF_USER_AGENT=NutriMindAI/0.1 (contact: <set-real-contact-email>)   # OFF etiquette: mandatory descriptive UA
OFF_CACHE_TTL_HOURS=168               # respectful caching (see DATA_SOURCES.md)
IFCT_DATASET_PATH=./data/ifct2017/    # licensed ICMR-NIN dataset drop point (acquisition = R-01)

# ----------------------------------------------------------------------------
# Observability (Phase 2)
# ----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nutrimind-api       # workers override: nutrimind-workers
SENTRY_DSN=                           # error monitoring hook (backend); mobile DSN in app config

# ----------------------------------------------------------------------------
# Push notifications (Phase 10)
# ----------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_PATH=        # FCM v1 service-account JSON path
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_KEY_PATH=                        # .p8 auth key
APNS_BUNDLE_ID=

# ----------------------------------------------------------------------------
# Mobile build-time config (Phase 4; passed via --dart-define / CI secrets)
# ----------------------------------------------------------------------------
# MOBILE_SUPABASE_URL / MOBILE_SUPABASE_ANON_KEY / MOBILE_API_BASE_URL / MOBILE_SENTRY_DSN

# ----------------------------------------------------------------------------
# CI/CD (Phase 12)
# ----------------------------------------------------------------------------
ANDROID_KEYSTORE_BASE64=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=
PLAY_SERVICE_ACCOUNT_JSON_PATH=

# ============================================================================
# ADDENDUM (Phases 13–19) — listed now so acquisition can start early
# ============================================================================
FITBIT_CLIENT_ID=                     # Phase 13 — dev.fitbit.com app registration
FITBIT_CLIENT_SECRET=
GARMIN_CONSUMER_KEY=                  # Phase 13 — Garmin Health API developer program
GARMIN_CONSUMER_SECRET=
DEXCOM_CLIENT_ID=                     # Phase 14 — developer.dexcom.com (sandbox first)
DEXCOM_CLIENT_SECRET=
DEXCOM_ENV=sandbox                    # sandbox | production (production = partnership blocker)
CLOUD_STT_PROVIDER=                   # Phase 15 — cloud STT fallback via gateway (ADR per locale)
